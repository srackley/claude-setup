# Ignore everything by default — only explicitly allowed files are tracked.
*

# Root files
!.gitignore
!CLAUDE.md
!mcp.json
!settings.json
!statusline-command.sh

# Directories (must un-ignore dir + contents separately)
!agents/
!agents/**
!hooks/
!hooks/**
!rules/
!rules/**
!skills/
!skills/**

# Re-ignore within allowed dirs
**/.DS_Store
